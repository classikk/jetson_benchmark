# REMEMBER: docker pull nvidia/cuda:13.0.0-devel-ubuntu22.04
FROM nvidia/cuda:13.0.0-devel-ubuntu22.04 AS compiler-base-base

FROM compiler-base-base AS compiler-base
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    pkg-config \
    python3 \
    python3-pip \
    python3-dev \
    libopencv-dev \
    g++ 
    #\
    #&& rm -rf /var/lib/apt/lists/*

FROM compiler-base AS main
RUN apt-get update && apt-get install -y --no-install-recommends tmux

WORKDIR /src